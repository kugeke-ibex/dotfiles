font-family = "Ricty Diminished"
font-family = "MesloLGS NF"
font-size = 14
theme = "Jetpack"

# zsh-syntax-highlighting / zeno / autosuggestions と zle-line-init の競合を避ける。
# (自動注入は _zsh_highlight: bad set of key/value pairs を誘発しうる)
# cwd 通知は config/zsh/common.zsh の OSC 7 precmd で代替。
shell-integration = none
background-opacity = 0.55
maximize = true
window-padding-x = 8
window-padding-y = 8
mouse-hide-while-typing = true
copy-on-select = clipboard

# ペイン/split 閉じるときの確認ダイアログを出さない（WezTerm の CloseCurrentPane confirm=false 相当）
confirm-close-surface = false

# リサイズ時のサイズ表示オーバーレイ（既定 750ms はキーリピート時に重く感じる）
resize-overlay-duration = 150ms

# Hotkey 表示/非表示は Karabiner Ctrl+Opt+G → toggle-ghostty-hotkey（Quick Terminal は使わない）

# --- Keybindings (iTerm2 / cmux 風) ---

# Pane splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Focus split (iTerm2 風: Cmd+[ / Cmd+])
keybind = cmd+left_bracket=goto_split:previous
keybind = cmd+right_bracket=goto_split:next

# Resize split (Ctrl+Shift+Arrow)。10px だと遅いので 50px（WezTerm はセル 5 相当）
keybind = ctrl+shift+left=resize_split:left,50
keybind = ctrl+shift+down=resize_split:down,50
keybind = ctrl+shift+up=resize_split:up,50
keybind = ctrl+shift+right=resize_split:right,50

# Misc
keybind = cmd+w=close_surface
keybind = cmd+z=toggle_split_zoom
keybind = cmd+enter=toggle_fullscreen
keybind = cmd+k=clear_screen
keybind = cmd+shift+r=reload_config

# --- AI agent launcher (cmux 風) ---
# Cmd+Shift+A を prefix にしたシーケンス。次の 1 キーで起動する。
# 実体は config/zsh/ai-agents.zsh の claude/codex/gemini ラッパ（タイトルに
# "🤖 <agent> · <branch>" を設定）を text で送信して踏む。
keybind = cmd+shift+a>c=text:claude\n
keybind = cmd+shift+a>x=text:codex\n
keybind = cmd+shift+a>g=text:gemini\n
# 並列作業用: 右 split / 新規タブ（開いた先で agent を起動する）
keybind = cmd+shift+a>s=new_split:right
keybind = cmd+shift+a>t=new_tab
