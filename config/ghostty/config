font-family = MesloLGS NF
font-family = Ricty Diminished
font-size = 14
theme = tokyonight

# zsh-syntax-highlighting / zeno / autosuggestions と zle-line-init の競合を避ける。
# (自動注入は _zsh_highlight: bad set of key/value pairs を誘発しうる)
# cwd 通知は config/zsh/common.zsh の OSC 7 precmd で代替。
shell-integration = none
background-opacity = 0.55
maximize = true
window-padding-x = 8
window-padding-y = 8
mouse-hide-while-typing = true
copy-on-select = clipboard

# Hotkey 表示/非表示は Karabiner Ctrl+Opt+G → toggle-ghostty-hotkey（Quick Terminal は使わない）

# --- Keybindings (iTerm2 / cmux 風) ---

# Pane splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Focus split (Cmd+Opt+hjkl)
keybind = cmd+opt+h=goto_split:left
keybind = cmd+opt+j=goto_split:bottom
keybind = cmd+opt+k=goto_split:top
keybind = cmd+opt+l=goto_split:right

# Resize split (Ctrl+Shift+Arrow)
keybind = ctrl+shift+left=resize_split:left,10
keybind = ctrl+shift+down=resize_split:down,10
keybind = ctrl+shift+up=resize_split:up,10
keybind = ctrl+shift+right=resize_split:right,10

# Misc
keybind = cmd+z=toggle_split_zoom
keybind = cmd+enter=toggle_fullscreen
keybind = cmd+k=clear_screen
keybind = cmd+shift+r=reload_config
